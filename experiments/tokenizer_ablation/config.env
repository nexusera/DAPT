# ===== Tokenizer Ablation Config (READY TO RUN) =====
# 本文件用于 tokenizer 消融（T1~T4）。路径按远端 /data/ocean/DAPT 的真实结构写死。
# 若要多次重复实验，建议只改 OUT_ROOT（例如改成不同日期/实验名）。

# 基础 tokenizer（HuggingFace 名称或本地目录）
BASE_TOKENIZER="hfl/chinese-macbert-base"

# 词表输入
# keys-only（不带 min5）用于 tokenizer 注入（T2/T4）
KEYS_ONLY_FILE="/data/ocean/DAPT/biaozhu_keys_only.txt"
# keys-min5 用于 jieba userdict（build_dataset_final_slim 里会加载它）
KEYS_MIN5_FILE="/data/ocean/DAPT/biaozhu_keys_only_min5.txt"

# OCR vocab（raw/kept）
OCR_VOCAB_RAW="/data/ocean/DAPT/workspace/medical_vocab_ocr_only/vocab.txt"
OCR_VOCAB_KEPT="/data/ocean/DAPT/workspace/kept_vocab.txt"

# 语料与数据集输出
TRAIN_FILE="/data/ocean/DAPT/workspace/train_chunked.txt"

# OCR 路（带噪声）输入
OCR_JSON="/home/ocean/semi_label/ocr_rerun/char_ocr_9297.json"
OCR_TEXT_FILE="/data/ocean/DAPT/workspace/train_ocr_9297.txt"

# 噪声分桶边界（一次性预计算产物）
NOISE_BINS_JSON="/data/ocean/DAPT/workspace/noise_bins.json"
# 输出根目录（你偏好不带日期的固定目录）。
# 注意：重复跑会覆盖/混淆旧输出；如需并行或多次实验，建议临时改成子目录：
# OUT_ROOT="/data/ocean/DAPT/ablation/tokenizer/exp_xxx"
OUT_ROOT="/data/ocean/DAPT/ablation/tokenizer"

# build_dataset 参数
MAX_LEN=512
NUM_PROC=8
BATCH_SIZE=1000
# 1=shuffle, 0=no_shuffle（仅作用于非 OCR 路；OCR 路始终强制 no_shuffle）
SHUFFLE_SPLIT=1

# merge_datasets 配比（只作用于 train split）
OCR_REPEAT=1
NONOCR_REPEAT=1
MERGE_SHUFFLE=1
MERGE_SEED=42

# 对齐校验（只检查 train 前 N 条）
ALIGN_CHECK_SAMPLES=50

# quick-run 小语料（可选）
QUICK_LINES=20000

# quick-run OCR 子集大小（按 OCR_JSON 的前 N 条截取；必须保持顺序）
QUICK_OCR_DOCS=2000
